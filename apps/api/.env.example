# Development database. Dùng đúng thông tin trong docker-compose.yml.
DATABASE_URL="postgresql://postgres:secret@localhost:5433/flightdb"
REDIS_URL="redis://localhost:6379"

# Development secrets. Khi deploy production, đổi thành chuỗi mạnh và giữ bí mật.
JWT_SECRET="dev-access-secret-change-before-production"
JWT_REFRESH_SECRET="dev-refresh-secret-change-before-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"

# Hoa hồng mặc định cho đại lý khi chưa cấu hình rule riêng.
AGENCY_MARKUP_PERCENT=7
AGENCY_MARKUP_FIXED_VND=50000

# Email ở dev có thể để trống. Khi dùng Gmail, tạo App Password trong Google Account.
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="VietFly Agency <noreply@vietfly.vn>"

# Payment gateway ở dev đang chạy mock, chưa cần key thật.
PAYMENT_MOCK_MODE=true
VNPAY_TMN_CODE=""
VNPAY_HASH_SECRET=""
MOMO_PARTNER_CODE=""
MOMO_SECRET_KEY=""
ZALOPAY_APP_ID=""
ZALOPAY_KEY1=""
ZALOPAY_KEY2=""
